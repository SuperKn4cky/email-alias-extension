{
  "manifest_version": 3,
  "name": "Email Alias Studio",
  "short_name": "Alias Studio",
  "version": "0.1.0",
  "description": "Generate, recreate, and manage email aliases for your domain with Cloudflare Email Routing.",
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["storage", "activeTab", "scripting", "clipboardWrite"],
  "host_permissions": ["https://api.cloudflare.com/client/v4/*"],
  "minimum_chrome_version": "114",
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Email Alias Studio",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "24": "icon.png",
      "32": "icon.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
